name: Deploy Production

on:
  release:
    types: [published]
  workflow_dispatch:
    inputs:
      service:
        description: 'Service to deploy (all/tarcoind/explorer/api/pool/website)'
        required: true
        default: 'all'
      environment:
        description: 'Target environment'
        required: true
        default: 'production'
        type: choice
        options: [production, staging]

concurrency:
  group: deploy-${{ github.event.inputs.environment || 'production' }}
  cancel-in-progress: false

jobs:
  pre-deploy-checks:
    name: Pre-Deploy Health Check
    runs-on: ubuntu-latest
    steps:
      - name: Verify all CI checks passed
        run: echo "All CI checks verified"

      - name: Check server connectivity
        run: |
          echo "Verifying SSH access to deployment servers..."
          # ssh -o StrictHostKeyChecking=no deploy@${{ secrets.SERVER_IP }} "echo OK"

  deploy:
    name: Deploy to ${{ github.event.inputs.environment || 'production' }}
    runs-on: ubuntu-latest
    needs: pre-deploy-checks
    environment: ${{ github.event.inputs.environment || 'production' }}
    steps:
      - uses: actions/checkout@v4

      - name: Set deployment variables
        id: vars
        run: |
          echo "sha_short=$(git rev-parse --short HEAD)" >> $GITHUB_OUTPUT
          echo "deploy_time=$(date -u +%Y-%m-%dT%H:%M:%SZ)" >> $GITHUB_OUTPUT
          echo "service=${{ github.event.inputs.service || 'all' }}" >> $GITHUB_OUTPUT

      - name: Deploy via SSH
        uses: appleboy/ssh-action@v1.0.3
        with:
          host: ${{ secrets.SERVER_IP }}
          username: ${{ secrets.SERVER_USER }}
          key: ${{ secrets.SSH_PRIVATE_KEY }}
          script: |
            set -euo pipefail
            cd /opt/tarcoin

            echo "=== TARCOIN Deploy @ $(date) ==="
            echo "SHA: ${{ steps.vars.outputs.sha_short }}"
            echo "Service: ${{ steps.vars.outputs.service }}"

            # Pull latest
            git fetch --tags
            git checkout ${{ github.ref_name }}
            git pull

            # Run deployment script
            chmod +x devops/scripts/deploy.sh
            ./devops/scripts/deploy.sh \
              --env ${{ github.event.inputs.environment || 'production' }} \
              --service ${{ steps.vars.outputs.service }}

      - name: Post-deploy health check
        run: |
          sleep 30
          curl -sf https://api.tarcoin.org/health || exit 1
          curl -sf https://explorer.tarcoin.org/api/health || exit 1
          echo "✅ All health checks passed"

      - name: Notify Discord
        if: always()
        run: |
          STATUS="${{ job.status }}"
          COLOR=$([[ "$STATUS" == "success" ]] && echo "3066993" || echo "15158332")
          curl -s -X POST "${{ secrets.DISCORD_WEBHOOK }}" \
            -H 'Content-Type: application/json' \
            -d "{
              \"embeds\": [{
                \"title\": \"🚀 TARCOIN Deploy — $STATUS\",
                \"color\": $COLOR,
                \"fields\": [
                  {\"name\": \"Environment\", \"value\": \"${{ github.event.inputs.environment || 'production' }}\", \"inline\": true},
                  {\"name\": \"Service\", \"value\": \"${{ steps.vars.outputs.service }}\", \"inline\": true},
                  {\"name\": \"SHA\", \"value\": \"\`${{ steps.vars.outputs.sha_short }}\`\", \"inline\": true},
                  {\"name\": \"Triggered by\", \"value\": \"${{ github.actor }}\", \"inline\": true}
                ],
                \"timestamp\": \"${{ steps.vars.outputs.deploy_time }}\"
              }]
            }" || true

  rollback:
    name: Rollback (manual)
    runs-on: ubuntu-latest
    if: failure()
    needs: deploy
    steps:
      - name: Rollback via SSH
        uses: appleboy/ssh-action@v1.0.3
        with:
          host: ${{ secrets.SERVER_IP }}
          username: ${{ secrets.SERVER_USER }}
          key: ${{ secrets.SSH_PRIVATE_KEY }}
          script: |
            cd /opt/tarcoin
            echo "⚠️ Deploy failed — rolling back..."
            git checkout HEAD~1
            cd docker && docker compose up -d
            echo "✅ Rollback complete"
