# TARCOIN Explorer Backend — Environment Variables

# Server
PORT=4000
NODE_ENV=development

# TARCOIN Node RPC
RPC_HOST=127.0.0.1
RPC_PORT=19332
RPC_USER=tarcoin
RPC_PASSWORD=tarcoin

# Redis Cache
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
