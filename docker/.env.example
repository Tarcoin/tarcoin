# TARCOIN Docker Environment Configuration
# Copy to .env and fill in values before deployment

# PostgreSQL
POSTGRES_PASSWORD=change_this_to_a_secure_password

# Mining Pool Wallet Address (where pool fees go)
POOL_WALLET=tar1q...

# Pool Fee Percentage (1 = 1%)
POOL_FEE=1

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_this_grafana_password

# Node Configuration (optional overrides)
TARCOIN_VERSION=1.0.0

# RPC Credentials
RPC_USER=tarcoin
RPC_PASSWORD=change_this_rpc_password

# CORS Origins
CORS_ORIGIN=https://tarcoin.org

# Next.js Public URLs
NEXT_PUBLIC_API_URL=https://api.tarcoin.org
NEXT_PUBLIC_EXPLORER_URL=https://explorer.tarcoin.org
NEXT_PUBLIC_POOL_URL=https://pool.tarcoin.org